{
  "openapi": "3.1.0",
  "info": {
    "title": "办公室绿萝 Pro API",
    "description": "办公室绿萝生长监测系统 v3.0 接口文档\n\n## 基础信息\n- 基础URL: http://localhost:5501/api\n- 数据格式: JSON\n- 编码: UTF-8",
    "version": "3.0.0"
  },
  "tags": [
    {"name": "叶片管理", "description": "叶片档案的增删改查接口"},
    {"name": "观测记录", "description": "叶片观测历史记录接口"},
    {"name": "检测识别", "description": "YOLO目标检测相关接口"},
    {"name": "监控管理", "description": "摄像头控制与系统监控接口"}
  ],
  "paths": {
    "/leaves": {
      "get": {
        "summary": "获取所有叶片",
        "description": "获取所有已确认的叶片档案列表",
        "tags": ["叶片管理"],
        "operationId": "getAllLeaves",
        "parameters": [],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/ConfirmedLeaf"},
                  "example": [
                    {
                      "leafId": "L0001",
                      "positionX": 320,
                      "positionY": 240,
                      "area": 4521.5,
                      "colorH": 65.2,
                      "colorS": 0.72,
                      "colorV": 0.85,
                      "circularity": 0.91,
                      "healthStatus": "HEALTHY",
                      "growthPercentage": 45.5,
                      "confirmedAt": "2026-04-28T10:30:00",
                      "lastObservationTime": "2026-04-29T08:00:00",
                      "imagePath": "/data/captures/leaf_L0001.jpg",
                      "annotatedImagePath": "/data/captures/annotated_L0001.jpg",
                      "notes": "东窗边第二盆第一片"
                    }
                  ]
                }
              }
            }
          }
        },
        "x-apifox-folder": "一、叶片相关接口",
        "x-apifox-status": "developing"
      },
      "post": {
        "summary": "确认新叶片",
        "description": "将检测到的叶片加入已确认档案",
        "tags": ["叶片管理"],
        "operationId": "confirmLeaf",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/LeafObservation"},
              "example": {
                "leafId": "L0001",
                "observationTime": "2026-04-29T08:00:00",
                "imagePath": "/data/captures/detected_001.jpg",
                "area": 4521.5,
                "colorH": 65.2,
                "colorS": 0.72,
                "colorV": 0.85,
                "centroidX": 320.0,
                "centroidY": 240.0,
                "status": "HEALTHY",
                "matchConfidence": 0.95,
                "positionX": 320,
                "positionY": 240,
                "source": "DETECTED"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ConfirmedLeaf"}
              }
            }
          }
        },
        "x-apifox-folder": "一、叶片相关接口",
        "x-apifox-status": "developing"
      }
    },
    "/leaves/{leafId}": {
      "get": {
        "summary": "获取叶片详情",
        "description": "根据ID获取单个叶片的详细信息",
        "tags": ["叶片管理"],
        "operationId": "getLeafById",
        "parameters": [
          {"name": "leafId", "in": "path", "required": true, "schema": {"type": "string"}, "description": "叶片唯一标识，如L0001", "example": "L0001"}
        ],
        "responses": {
          "200": {"description": "成功", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ConfirmedLeaf"}}}},
          "404": {"description": "叶片不存在", "content": {"application/json": {"schema": {"type": "object", "properties": {"error": {"type": "string"}}}}}}
        },
        "x-apifox-folder": "一、叶片相关接口",
        "x-apifox-status": "developing"
      },
      "put": {
        "summary": "更新叶片信息",
        "description": "根据最新观测记录更新叶片档案",
        "tags": ["叶片管理"],
        "operationId": "updateLeaf",
        "parameters": [
          {"name": "leafId", "in": "path", "required": true, "schema": {"type": "string"}, "description": "叶片ID"}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/LeafObservation"}
            }
          }
        },
        "responses": {
          "200": {"description": "成功", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ConfirmedLeaf"}}}},
          "404": {"description": "叶片不存在"}
        },
        "x-apifox-folder": "一、叶片相关接口",
        "x-apifox-status": "developing"
      },
      "delete": {
        "summary": "删除叶片",
        "description": "删除叶片档案，级联删除该叶片的所有观测记录",
        "tags": ["叶片管理"],
        "operationId": "deleteLeaf",
        "parameters": [
          {"name": "leafId", "in": "path", "required": true, "schema": {"type": "string"}, "description": "叶片ID"}
        ],
        "responses": {
          "204": {"description": "删除成功，无返回内容"},
          "404": {"description": "叶片不存在"}
        },
        "x-apifox-folder": "一、叶片相关接口",
        "x-apifox-status": "developing"
      }
    },
    "/leaves/attention": {
      "get": {
        "summary": "获取需关注叶片",
        "description": "返回健康状态异常的叶片（黄叶、枯萎、预警状态）",
        "tags": ["叶片管理"],
        "operationId": "getLeavesNeedingAttention",
        "parameters": [],
        "responses": {
          "200": {"description": "成功", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/ConfirmedLeaf"}}}}}
        },
        "x-apifox-folder": "一、叶片相关接口",
        "x-apifox-status": "developing"
      }
    },
    "/leaves/statistics": {
      "get": {
        "summary": "获取叶片统计",
        "description": "返回叶片总数、各状态数量等统计信息",
        "tags": ["叶片管理"],
        "operationId": "getStatistics",
        "parameters": [],
        "responses": {
          "200": {"description": "成功", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/LeafStatistics"}}}}
        },
        "x-apifox-folder": "一、叶片相关接口",
        "x-apifox-status": "developing"
      }
    },
    "/leaves/{leafId}/observations": {
      "get": {
        "summary": "获取历史观测记录",
        "description": "获取指定叶片的所有历史观测记录，按时间倒序",
        "tags": ["观测记录"],
        "operationId": "getLeafObservations",
        "parameters": [
          {"name": "leafId", "in": "path", "required": true, "schema": {"type": "string"}, "description": "叶片ID"}
        ],
        "responses": {
          "200": {"description": "成功", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/LeafObservation"}}}}}
        },
        "x-apifox-folder": "二、观测记录接口",
        "x-apifox-status": "developing"
      }
    },
    "/leaves/{leafId}/observations/recent": {
      "get": {
        "summary": "获取最近观测记录",
        "description": "获取叶片最近的N条观测记录",
        "tags": ["观测记录"],
        "operationId": "getRecentObservations",
        "parameters": [
          {"name": "leafId", "in": "path", "required": true, "schema": {"type": "string"}, "description": "叶片ID"},
          {"name": "limit", "in": "query", "required": false, "schema": {"type": "integer", "default": 10}, "description": "返回记录数量，默认10"}
        ],
        "responses": {
          "200": {"description": "成功", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/LeafObservation"}}}}}
        },
        "x-apifox-folder": "二、观测记录接口",
        "x-apifox-status": "developing"
      }
    },
    "/detect": {
      "post": {
        "summary": "执行目标检测",
        "description": "对指定图片进行YOLO目标检测，返回检测结果",
        "tags": ["检测识别"],
        "operationId": "detect",
        "parameters": [
          {"name": "imagePath", "in": "query", "required": true, "schema": {"type": "string"}, "description": "图片路径，可以是绝对路径或相对于data/captures/的路径"}
        ],
        "responses": {
          "200": {"description": "检测成功", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/DetectionResponse"}}}},
          "400": {"description": "检测失败"}
        },
        "x-apifox-folder": "三、检测识别接口",
        "x-apifox-status": "developing"
      }
    },
    "/detect/batch": {
      "post": {
        "summary": "批量目标检测",
        "description": "对多张图片进行批量YOLO目标检测",
        "tags": ["检测识别"],
        "operationId": "detectBatch",
        "parameters": [
          {"name": "imagePaths", "in": "query", "required": true, "schema": {"type": "string"}, "description": "多张图片路径，用英文逗号分隔"}
        ],
        "responses": {
          "200": {"description": "批量检测完成"}
        },
        "x-apifox-folder": "三、检测识别接口",
        "x-apifox-status": "developing"
      }
    },
    "/detect/annotated-image": {
      "get": {
        "summary": "获取标注图片",
        "description": "返回带有检测框标注的图片",
        "tags": ["检测识别"],
        "operationId": "getAnnotatedImage",
        "parameters": [
          {"name": "imagePath", "in": "query", "required": true, "schema": {"type": "string"}, "description": "原图路径"}
        ],
        "responses": {
          "200": {"description": "返回标注后的JPEG图片", "content": {"image/jpeg": {"schema": {"type": "string", "format": "binary"}}}}}
        },
        "x-apifox-folder": "三、检测识别接口",
        "x-apifox-status": "developing"
      }
    },
    "/monitor/capture": {
      "post": {
        "summary": "拍摄图片",
        "description": "控制摄像头拍摄一张图片并保存",
        "tags": ["监控管理"],
        "operationId": "captureImage",
        "parameters": [],
        "responses": {
          "200": {"description": "拍摄成功", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/CaptureResult"}}}}
        },
        "x-apifox-folder": "四、监控管理接口",
        "x-apifox-status": "developing"
      }
    },
    "/monitor/status": {
      "get": {
        "summary": "获取监控状态",
        "description": "获取系统监控状态、摄像头状态等",
        "tags": ["监控管理"],
        "operationId": "getMonitorStatus",
        "parameters": [],
        "responses": {
          "200": {"description": "成功", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/MonitorStatus"}}}}
        },
        "x-apifox-folder": "四、监控管理接口",
        "x-apifox-status": "developing"
      }
    },
    "/model/status": {
      "get": {
        "summary": "获取模型状态",
        "description": "获取YOLO模型加载状态和配置信息",
        "tags": ["检测识别"],
        "operationId": "getModelStatus",
        "parameters": [],
        "responses": {
          "200": {"description": "成功", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ModelStatus"}}}}
        },
        "x-apifox-folder": "三、检测识别接口",
        "x-apifox-status": "developing"
      }
    }
  },
  "components": {
    "schemas": {
      "ConfirmedLeaf": {
        "type": "object",
        "description": "已确认叶片档案",
        "properties": {
          "leafId": {"type": "string", "description": "叶片唯一标识，主键，如L0001", "example": "L0001"},
          "positionX": {"type": "integer", "description": "首次发现时的中心X坐标", "example": 320},
          "positionY": {"type": "integer", "description": "首次发现时的中心Y坐标", "example": 240},
          "area": {"type": "number", "description": "首次发现时的面积（像素数）", "example": 4521.5},
          "colorH": {"type": "number", "description": "HSV颜色H值，色相，核心健康指标", "example": 65.2},
          "colorS": {"type": "number", "description": "HSV颜色S值，饱和度", "example": 0.72},
          "colorV": {"type": "number", "description": "HSV颜色V值，亮度", "example": 0.85},
          "circularity": {"type": "number", "description": "圆形度=4π×面积/周长²，取值0-1，越接近1越圆", "example": 0.91},
          "imagePath": {"type": "string", "description": "叶片首次发现的图片路径"},
          "annotatedImagePath": {"type": "string", "description": "标注图路径，用于前端展示检测结果"},
          "contourPoints": {"type": "string", "description": "Hu矩轮廓特征，7维特征向量，旋转缩放不变"},
          "healthStatus": {"type": "string", "description": "叶片当前健康状态", "enum": ["HEALTHY", "YELLOW_LEAF", "WILT", "WILT_WARNING"], "example": "HEALTHY"},
          "growthPercentage": {"type": "number", "description": "叶片累计成长百分比", "example": 45.5},
          "confirmedAt": {"type": "string", "format": "date-time", "description": "叶片确认时间，ISO 8601格式", "example": "2026-04-28T10:30:00"},
          "lastObservationTime": {"type": "string", "format": "date-time", "description": "最后一次观测时间", "example": "2026-04-29T08:00:00"},
          "lastAlertTime": {"type": "string", "format": "date-time", "description": "最后一次预警时间，用于冷却控制"},
          "notes": {"type": "string", "description": "用户备注信息", "example": "东窗边第二盆第一片"},
          "createdAt": {"type": "string", "format": "date-time", "description": "创建时间"},
          "updatedAt": {"type": "string", "format": "date-time", "description": "更新时间"}
        },
        "required": ["leafId", "healthStatus", "confirmedAt"]
      },
      "LeafObservation": {
        "type": "object",
        "description": "叶片观测记录实体",
        "properties": {
          "id": {"type": "integer", "format": "int64", "description": "观测记录ID，自增主键"},
          "leafId": {"type": "string", "description": "关联的叶片ID，外键指向confirmed_leaves表", "example": "L0001"},
          "observationTime": {"type": "string", "format": "date-time", "description": "观测时间（拍摄时间）", "example": "2026-04-29T08:00:00"},
          "imagePath": {"type": "string", "description": "原始图片路径"},
          "area": {"type": "number", "description": "叶片面积（像素数）", "example": 4521.5},
          "colorH": {"type": "number", "description": "HSV颜色H值，色相，0-180范围", "example": 65.2},
          "colorS": {"type": "number", "description": "HSV颜色S值，饱和度", "example": 0.72},
          "colorV": {"type": "number", "description": "HSV颜色V值，亮度", "example": 0.85},
          "centroidX": {"type": "number", "description": "叶片中心X坐标", "example": 320.0},
          "centroidY": {"type": "number", "description": "叶片中心Y坐标", "example": 240.0},
          "status": {"type": "string", "description": "叶片健康状态", "enum": ["HEALTHY", "YELLOW_LEAF", "WILT", "WILT_WARNING", "TREND_YELLOW", "TREND_WILT"], "example": "HEALTHY"},
          "matchConfidence": {"type": "number", "description": "匹配置信度，0到1，越高表示匹配越准确", "example": 0.95},
          "captureTime": {"type": "string", "format": "date-time", "description": "捕获时间（系统记录时间）"},
          "annotatedImagePath": {"type": "string", "description": "标注图路径"},
          "positionX": {"type": "integer", "description": "叶片位置X（用于历史对比）"},
          "positionY": {"type": "integer", "description": "叶片位置Y（用于历史对比）"},
          "source": {"type": "string", "description": "数据来源", "enum": ["DETECTED", "MANUAL"], "example": "DETECTED"},
          "createdAt": {"type": "string", "format": "date-time", "description": "创建时间"}
        }
      },
      "LeafStatistics": {
        "type": "object",
        "description": "叶片统计信息",
        "properties": {
          "totalLeaves": {"type": "integer", "description": "叶片总数", "example": 5},
          "attentionCount": {"type": "integer", "description": "需关注叶片数量", "example": 1},
          "statusCounts": {"type": "object", "description": "各状态叶片数量", "example": {"HEALTHY": 4, "YELLOW_LEAF": 1}}
        }
      },
      "DetectionResponse": {
        "type": "object",
        "description": "YOLO检测响应",
        "properties": {
          "success": {"type": "boolean", "description": "检测是否成功"},
          "imagePath": {"type": "string", "description": "原图路径"},
          "annotatedImagePath": {"type": "string", "description": "标注图路径"},
          "detectionCount": {"type": "integer", "description": "检测到的目标数量"},
          "detections": {"type": "array", "description": "检测结果列表", "items": {"$ref": "#/components/schemas/DetectionItem"}},
          "message": {"type": "string", "description": "错误信息"}
        }
      },
      "DetectionItem": {
        "type": "object",
        "description": "单个检测结果",
        "properties": {
          "className": {"type": "string", "description": "类别名称", "example": "healthy_leaf"},
          "confidence": {"type": "number", "description": "置信度", "example": 0.95},
          "bbox": {"type": "object", "description": "边界框", "properties": {"x": {"type": "integer"}, "y": {"type": "integer"}, "width": {"type": "integer"}, "height": {"type": "integer"}}}
        }
      },
      "CaptureResult": {
        "type": "object",
        "description": "摄像头拍摄结果",
        "properties": {
          "success": {"type": "boolean", "description": "拍摄是否成功"},
          "imagePath": {"type": "string", "description": "保存的图片路径"},
          "timestamp": {"type": "string", "format": "date-time", "description": "拍摄时间"}
        }
      },
      "MonitorStatus": {
        "type": "object",
        "description": "监控系统状态",
        "properties": {
          "cameraEnabled": {"type": "boolean", "description": "摄像头是否启用"},
          "cameraIndex": {"type": "integer", "description": "摄像头索引"},
          "lastCaptureTime": {"type": "string", "format": "date-time", "description": "最后拍摄时间"},
          "imageCount": {"type": "integer", "description": "已保存图片数量"}
        }
      },
      "ModelStatus": {
        "type": "object",
        "description": "YOLO模型状态",
        "properties": {
          "loaded": {"type": "boolean", "description": "模型是否已加载"},
          "modelPath": {"type": "string", "description": "模型文件路径"},
          "modelSize": {"type": "string", "description": "模型文件大小"},
          "confThreshold": {"type": "number", "description": "置信度阈值"},
          "iouThreshold": {"type": "number", "description": "IOU阈值"},
          "enabled": {"type": "boolean", "description": "模型是否启用"}
        }
      }
    },
    "responses": {
      "NotFound": {"description": "资源不存在"},
      "BadRequest": {"description": "请求参数错误"}
    }
  },
  "servers": [
    {"url": "http://localhost:5501/api", "description": "本地开发环境"}
  ]
}
