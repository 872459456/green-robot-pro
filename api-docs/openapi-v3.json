{
  "openapi": "3.0.3",
  "info": {
    "title": "办公室绿萝 Pro API",
    "description": "办公室绿萝生长监测系统 v3.0 接口文档",
    "version": "3.0.0"
  },
  "servers": [
    {"url": "http://localhost:5501/api", "description": "本地开发环境"}
  ],
  "paths": {
    "/leaves": {
      "get": {
        "summary": "获取所有叶片",
        "description": "获取所有已确认的叶片档案列表",
        "tags": ["叶片管理"],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/ConfirmedLeaf"}
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "确认新叶片",
        "description": "将检测到的叶片加入已确认档案",
        "tags": ["叶片管理"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/LeafObservation"}
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ConfirmedLeaf"}
              }
            }
          }
        }
      }
    },
    "/leaves/{leafId}": {
      "get": {
        "summary": "获取叶片详情",
        "description": "根据ID获取单个叶片的详细信息",
        "tags": ["叶片管理"],
        "parameters": [
          {"name": "leafId", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ConfirmedLeaf"}
              }
            }
          },
          "404": {"description": "叶片不存在"}
        }
      },
      "put": {
        "summary": "更新叶片信息",
        "description": "根据最新观测记录更新叶片档案",
        "tags": ["叶片管理"],
        "parameters": [
          {"name": "leafId", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/LeafObservation"}
            }
          }
        },
        "responses": {
          "200": {"description": "成功"},
          "404": {"description": "叶片不存在"}
        }
      },
      "delete": {
        "summary": "删除叶片",
        "description": "删除叶片档案，级联删除该叶片的所有观测记录",
        "tags": ["叶片管理"],
        "parameters": [
          {"name": "leafId", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "204": {"description": "删除成功"},
          "404": {"description": "叶片不存在"}
        }
      }
    },
    "/leaves/attention": {
      "get": {
        "summary": "获取需关注叶片",
        "description": "返回健康状态异常的叶片（黄叶、枯萎、预警状态）",
        "tags": ["叶片管理"],
        "responses": {
          "200": {"description": "成功"}
        }
      }
    },
    "/leaves/statistics": {
      "get": {
        "summary": "获取叶片统计",
        "description": "返回叶片总数、各状态数量等统计信息",
        "tags": ["叶片管理"],
        "responses": {
          "200": {"description": "成功"}
        }
      }
    },
    "/leaves/{leafId}/observations": {
      "get": {
        "summary": "获取历史观测记录",
        "description": "获取指定叶片的所有历史观测记录，按时间倒序",
        "tags": ["观测记录"],
        "parameters": [
          {"name": "leafId", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "成功"}
        }
      }
    },
    "/leaves/{leafId}/observations/recent": {
      "get": {
        "summary": "获取最近观测记录",
        "description": "获取叶片最近的N条观测记录",
        "tags": ["观测记录"],
        "parameters": [
          {"name": "leafId", "in": "path", "required": true, "schema": {"type": "string"}},
          {"name": "limit", "in": "query", "schema": {"type": "integer", "default": 10}}
        ],
        "responses": {
          "200": {"description": "成功"}
        }
      }
    },
    "/detect": {
      "post": {
        "summary": "执行目标检测",
        "description": "对指定图片进行YOLO目标检测",
        "tags": ["检测识别"],
        "parameters": [
          {"name": "imagePath", "in": "query", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "检测成功"},
          "400": {"description": "检测失败"}
        }
      }
    },
    "/detect/batch": {
      "post": {
        "summary": "批量目标检测",
        "description": "对多张图片进行批量YOLO目标检测",
        "tags": ["检测识别"],
        "parameters": [
          {"name": "imagePaths", "in": "query", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "批量检测完成"}
        }
      }
    },
    "/detect/annotated-image": {
      "get": {
        "summary": "获取标注图片",
        "description": "返回带有检测框标注的图片",
        "tags": ["检测识别"],
        "parameters": [
          {"name": "imagePath", "in": "query", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "返回标注后的JPEG图片"}
        }
      }
    },
    "/monitor/capture": {
      "post": {
        "summary": "拍摄图片",
        "description": "控制摄像头拍摄一张图片并保存",
        "tags": ["监控管理"],
        "responses": {
          "200": {"description": "拍摄成功"}
        }
      }
    },
    "/monitor/status": {
      "get": {
        "summary": "获取监控状态",
        "description": "获取系统监控状态、摄像头状态等",
        "tags": ["监控管理"],
        "responses": {
          "200": {"description": "成功"}
        }
      }
    },
    "/model/status": {
      "get": {
        "summary": "获取模型状态",
        "description": "获取YOLO模型加载状态和配置信息",
        "tags": ["检测识别"],
        "responses": {
          "200": {"description": "成功"}
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ConfirmedLeaf": {
        "type": "object",
        "properties": {
          "leafId": {"type": "string", "description": "叶片唯一标识，如L0001"},
          "positionX": {"type": "integer", "description": "首次发现时的中心X坐标"},
          "positionY": {"type": "integer", "description": "首次发现时的中心Y坐标"},
          "area": {"type": "number", "description": "首次发现时的面积（像素数）"},
          "colorH": {"type": "number", "description": "HSV颜色H值"},
          "colorS": {"type": "number", "description": "HSV颜色S值"},
          "colorV": {"type": "number", "description": "HSV颜色V值"},
          "circularity": {"type": "number", "description": "圆形度"},
          "imagePath": {"type": "string", "description": "叶片图片路径"},
          "annotatedImagePath": {"type": "string", "description": "标注图路径"},
          "healthStatus": {"type": "string", "enum": ["HEALTHY", "YELLOW_LEAF", "WILT", "WILT_WARNING"]},
          "growthPercentage": {"type": "number", "description": "累计成长百分比"},
          "confirmedAt": {"type": "string", "format": "date-time"},
          "lastObservationTime": {"type": "string", "format": "date-time"},
          "lastAlertTime": {"type": "string", "format": "date-time"},
          "notes": {"type": "string", "description": "用户备注"},
          "createdAt": {"type": "string", "format": "date-time"},
          "updatedAt": {"type": "string", "format": "date-time"}
        }
      },
      "LeafObservation": {
        "type": "object",
        "properties": {
          "id": {"type": "integer", "format": "int64"},
          "leafId": {"type": "string"},
          "observationTime": {"type": "string", "format": "date-time"},
          "imagePath": {"type": "string"},
          "area": {"type": "number"},
          "colorH": {"type": "number"},
          "colorS": {"type": "number"},
          "colorV": {"type": "number"},
          "centroidX": {"type": "number"},
          "centroidY": {"type": "number"},
          "status": {"type": "string"},
          "matchConfidence": {"type": "number"},
          "captureTime": {"type": "string", "format": "date-time"},
          "annotatedImagePath": {"type": "string"},
          "positionX": {"type": "integer"},
          "positionY": {"type": "integer"},
          "source": {"type": "string", "enum": ["DETECTED", "MANUAL"]},
          "createdAt": {"type": "string", "format": "date-time"}
        }
      }
    }
  }
}